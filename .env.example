# ════════════════════════════════════════════════════════════════
#  GeminiChat — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your actual .env file to version control.
# ════════════════════════════════════════════════════════════════


# ── Gemini AI ─────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# ── MySQL Database ────────────────────────────────────────────
# The app will auto-create the database and tables on first run.

# ┌─ LOCAL (development) ───────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=chatapp

# ┌─ CLOUD OPTIONS (pick one for deployment) ───────────────────
#
# 1. Railway  →  https://railway.app  (free tier available)
#    MYSQL_HOST=your-host.proxy.rlwy.net
#    MYSQL_PORT=your_public_port
#    MYSQL_USER=root
#    MYSQL_PASSWORD=your_railway_password
#    MYSQL_DATABASE=railway
#
# 2. PlanetScale  →  https://planetscale.com  (serverless MySQL)
#    MYSQL_HOST=aws.connect.psdb.cloud
#    MYSQL_PORT=3306
#    MYSQL_USER=your_username
#    MYSQL_PASSWORD=your_planetscale_password
#    MYSQL_DATABASE=chatapp
#
# 3. Aiven  →  https://aiven.io  (free 1-month trial)
#    MYSQL_HOST=mysql-xxxx.aivencloud.com
#    MYSQL_PORT=your_port
#    MYSQL_USER=avnadmin
#    MYSQL_PASSWORD=your_aiven_password
#    MYSQL_DATABASE=defaultdb
#
# 4. Clever Cloud  →  https://clever-cloud.com  (free MySQL)
#    MYSQL_HOST=<host>.services.clever-cloud.com
#    MYSQL_PORT=3306
#    MYSQL_USER=<cc-user>
#    MYSQL_PASSWORD=<cc-password>
#    MYSQL_DATABASE=<cc-database>
